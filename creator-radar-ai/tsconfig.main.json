{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "CommonJS",
    "moduleResolution":"node",
    "strict":          true,
    "esModuleInterop": true,
    "skipLibCheck":    true,
    "resolveJsonModule":true,
    "outDir":          "dist/main",
    "rootDir":         "src/main",
    "baseUrl":         ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/main/**/*", "src/shared/**/*"],
  "exclude": ["node_modules", "dist"]
}

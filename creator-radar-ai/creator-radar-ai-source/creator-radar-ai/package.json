{
  "name": "creator-radar-ai",
  "version": "1.0.0",
  "description": "CreatorRadar AI — Creator Recruiting Assistant for Windows",
  "main": "dist/main/main.js",
  "author": "CreatorRadar AI",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev":              "node scripts/dev-start.js",
    "dev:renderer":     "vite --config vite.renderer.config.ts",
    "dev:main":         "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "build":            "npm run build:main && npm run build:renderer",
    "build:main":       "tsc -p tsconfig.main.json",
    "build:renderer":   "vite build --config vite.renderer.config.ts",
    "package":          "node scripts/build-installer.js",
    "package:quick":    "npm run build && electron-builder --win --config electron-builder.yml",
    "package:dir":      "npm run build && electron-builder --win --dir",
    "postinstall":      "electron-builder install-app-deps",
    "setup":            "node scripts/create-placeholder-icon.js",
    "verify":           "node scripts/verify-setup.js",
    "smoke-test":       "node scripts/smoke-test-export.js",
    "build-installer":  "node scripts/build-installer.js",
    "lint":             "eslint src --ext .ts,.tsx",
    "typecheck":        "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "exceljs":        "^4.4.0",
    "react":          "^18.2.0",
    "react-dom":      "^18.2.0",
    "react-router-dom":"^6.22.0",
    "recharts":       "^2.10.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin":"^7.0.0",
    "@typescript-eslint/parser":       "^7.0.0",
    "@types/better-sqlite3":           "^7.6.8",
    "@types/node":                     "^20.11.5",
    "@types/react":                    "^18.2.48",
    "@types/react-dom":                "^18.2.18",
    "@vitejs/plugin-react":            "^4.2.1",
    "concurrently":                    "^8.2.2",
    "cross-env":                       "^7.0.3",
    "electron":                        "^29.0.0",
    "electron-builder":                "^24.9.1",
    "eslint":                          "^8.57.0",
    "eslint-plugin-react":             "^7.34.0",
    "eslint-plugin-react-hooks":       "^4.6.0",
    "typescript":                      "^5.3.3",
    "vite":                            "^5.0.12",
    "wait-on":                         "^7.2.0"
  }
}

{
  "compilerOptions": {
    "target":     "ES2020",
    "module":     "ESNext",
    "moduleResolution": "bundler",
    "strict":     true,
    "jsx":        "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl":    ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "exclude": ["node_modules", "dist", "dist-installer"]
}
